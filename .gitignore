#
# --- Environment / Secrets ---
.env
.env.local
*.env.local

# --- Python ---
.venv/
__pycache__/
*.py[cod]
*$py.class
.Python
*.pyo
*.pyc


# --- Backups ---
*.bak
*.backup
*.old
*.orig
*.tmp

# --- Workspace ---
workspace/
*.code-workspace
*.workspace

# --- Runtime-Daten ---
state/*.json
!state/.gitkeep

# --- IDE ---
.vscode/
.idea/
*.swp

# --- OS ---
.DS_Store
._* 
Thumbs.db

# --- Runtime / Logs ---
log/*.log
!log/.gitkeep