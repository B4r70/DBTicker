#  All rights reserved
# ===========================================================================================
#
from __future__ import annotations

import logging
import os
from datetime import datetime, timedelta
from pathlib import Path
from typing import Optional
from zoneinfo import ZoneInfo


# ------------------------------------------------------------------------------------------
#  Konfigurationen
# ------------------------------------------------------------------------------------------

BERLIN = ZoneInfo("Europe/Berlin")
PROJECT_ROOT = Path(__file__).resolve().parent.parent
LOG_DIR = PROJECT_ROOT / "log"
LOG_RETENTION_DAYS = 30


# ------------------------------------------------------------------------------------------
#  Cleanup für alte Logs
# ------------------------------------------------------------------------------------------

def _cleanup_old_logs() -> None:
    """Löscht Logdateien, die älter als LOG_RETENTION_DAYS sind.

    Wird beim Logging-Setup einmal aufgerufen. Fehler hier sind nicht
    fatal — im Zweifel lieber weiterlaufen als crashen.
    """
    cutoff = datetime.now() - timedelta(days=LOG_RETENTION_DAYS)

    try:
        for log_file in LOG_DIR.glob("dbticker-*.log"):
            if log_file.stat().st_mtime < cutoff.timestamp():
                log_file.unlink()
    except OSError:
        # Log-Verzeichnis existiert nicht oder keine Schreibrechte — ignorieren
        pass


# ------------------------------------------------------------------------------------------
#  Berlin-Zeitzone Formatter
# ------------------------------------------------------------------------------------------

class _BerlinFormatter(logging.Formatter):
    """Formatter, der Zeitstempel explizit in Europe/Berlin rendert.

    Standardmäßig nutzt Python die System-Zeitzone — die liegt auf dem Server
    aber in UTC. Mit diesem Formatter stimmen Log-Zeiten immer mit der Welt da
    draußen überein.
    """

    def formatTime(self, record, datefmt=None):
        dt = datetime.fromtimestamp(record.created, tz=BERLIN)
        if datefmt:
            return dt.strftime(datefmt)
        return dt.strftime("%Y-%m-%d %H:%M:%S")


# ------------------------------------------------------------------------------------------
#  File-Handler-Aufbau (kann scheitern → None zurück)
# ------------------------------------------------------------------------------------------

def _try_make_file_handler(formatter: logging.Formatter) -> Optional[logging.FileHandler]:
    """Versucht, einen FileHandler aufzubauen. Bei Fehler: None.

    Häufigste Ursachen für Fehler:
      - Log-Verzeichnis nicht beschreibbar (anderer User als beim Anlegen)
      - Subprocess startet aus einem CWD, wo PROJECT_ROOT/log nicht existiert
        und nicht angelegt werden kann (Permission)
      - Netzwerk-/Kontainerlaufzeit ohne persistente FS

    In all diesen Fällen ist es richtig, weiterzumachen — wir loggen ja noch
    nach stdout, was via systemd-journal eh dauerhaft persistiert wird.
    """
    try:
        LOG_DIR.mkdir(parents=True, exist_ok=True)
    except OSError as e:
        # Verzeichnis nicht erstellbar — einfach skippen
        return None

    # Schreibrecht-Check: kann ich überhaupt was reinschreiben?
    if not os.access(LOG_DIR, os.W_OK):
        return None

    today_str = datetime.now(BERLIN).strftime("%Y%m%d")
    logfile = LOG_DIR / f"dbticker-{today_str}.log"

    try:
        handler = logging.FileHandler(logfile, mode="a", encoding="utf-8")
    except (OSError, PermissionError):
        return None

    handler.setFormatter(formatter)
    handler.setLevel(logging.DEBUG)
    return handler


# ------------------------------------------------------------------------------------------
#  Public API
# ------------------------------------------------------------------------------------------

def configure_logging(level: int = logging.INFO) -> logging.Logger:
    """Initialisiert Logging für die gesamte Applikation.

    Sollte EINMAL aus main.py aufgerufen werden, bevor andere Module
    anfangen zu loggen.

    Stream-Handler ist immer aktiv (stdout → systemd-journal).
    File-Handler ist optional — wenn er nicht aufgebaut werden kann (z.B.
    weil das Log-Verzeichnis read-only ist), läuft alles weiter, nur ohne
    Datei-Persistenz.
    """
    formatter = _BerlinFormatter(
        fmt="%(asctime)s [%(levelname)s] %(name)s: %(message)s",
        datefmt="%Y-%m-%d %H:%M:%S",
    )

    # Handler 1: stdout — IMMER
    stream_handler = logging.StreamHandler()
    stream_handler.setFormatter(formatter)
    stream_handler.setLevel(level)

    # Handler 2: Datei — optional
    file_handler = _try_make_file_handler(formatter)

    # Cleanup nur, wenn wir überhaupt Datei-Logging machen
    if file_handler is not None:
        _cleanup_old_logs()

    # Root-Logger konfigurieren
    root = logging.getLogger()
    # Vorherige Handler entfernen (falls configure_logging mehrfach gerufen wird)
    for h in list(root.handlers):
        root.removeHandler(h)
    root.setLevel(logging.DEBUG if file_handler else level)
    root.addHandler(stream_handler)
    if file_handler is not None:
        root.addHandler(file_handler)

    logger = logging.getLogger("dbticker")
    if file_handler is not None:
        logger.info("Logging initialisiert (stdout + Datei: %s)", file_handler.baseFilename)
    else:
        logger.info("Logging initialisiert (stdout-only — Datei nicht beschreibbar)")
    return logger